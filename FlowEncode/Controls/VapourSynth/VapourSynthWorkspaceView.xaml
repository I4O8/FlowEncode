<UserControl
    x:Class="FlowEncode.Controls.VapourSynth.VapourSynthWorkspaceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="UserControl_Loaded"
    SizeChanged="UserControl_SizeChanged">
    <Grid
        x:Name="WorkspaceRoot"
        Background="{ThemeResource WindowBackgroundBrush}">
        <Border
            Background="{ThemeResource CardBrush}"
            BorderBrush="{ThemeResource CardBorderBrush}"
            BorderThickness="{StaticResource AppCardBorderThickness}"
            CornerRadius="{StaticResource AppLargeCornerRadius}" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="EditorRowDefinition" Height="*" />
                <RowDefinition Height="1" />
                <RowDefinition x:Name="LogRowDefinition" Height="160" />
            </Grid.RowDefinitions>

            <CommandBar
                x:Name="EditorCommandBar"
                Padding="10,8,10,8"
                Background="{ThemeResource CardBrush}"
                DefaultLabelPosition="Right"
                IsDynamicOverflowEnabled="True"
                OverflowButtonVisibility="Auto">
                <AppBarButton Click="NewDocumentButton_Click" Label="{Binding Texts.NewButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Page2" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Click="OpenDocumentButton_Click" Label="{Binding Texts.VapourSynthOpenButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="OpenFile" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Click="SaveDocumentButton_Click" Label="{Binding Texts.SaveButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Save" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Click="SaveDocumentAsButton_Click" Label="{Binding Texts.SaveAsButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="SaveLocal" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Click="ReloadDocumentButton_Click" IsEnabled="{Binding CanReload}" Label="{Binding Texts.VapourSynthReloadButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Refresh" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarButton Click="UndoButton_Click" Label="{Binding Texts.VapourSynthUndoButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Undo" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Click="RedoButton_Click" Label="{Binding Texts.VapourSynthRedoButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Redo" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarButton Click="FindButton_Click" Label="{Binding Texts.VapourSynthFindButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Find" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Click="ReplaceButton_Click" Label="{Binding Texts.VapourSynthReplaceButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Switch" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Click="GoToButton_Click" Label="{Binding Texts.VapourSynthGoToButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Forward" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarSeparator />
                <AppBarButton Click="PreviewButton_Click" Label="{Binding Texts.VapourSynthPreviewButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Play" />
                    </AppBarButton.Icon>
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F5" />
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
                <AppBarButton x:Name="EncodeButton" Click="EncodeButton_Click" Label="{Binding Texts.VapourSynthEncodeButton}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Video" />
                    </AppBarButton.Icon>
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F9" />
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
            </CommandBar>

            <Border
                Grid.Row="1"
                Padding="16,10,16,12"
                Background="{ThemeResource CardAltBrush}"
                BorderBrush="{ThemeResource CardBorderBrush}"
                BorderThickness="0,1,0,1">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontFamily="{StaticResource AppDisplayFont}"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Text="{Binding DocumentTitle}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            FontFamily="{StaticResource AppMonoFont}"
                            Foreground="{ThemeResource SubtleTextBrush}"
                            Text="{Binding DocumentPathText}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="6">
                        <Border
                            Padding="10,4"
                            HorizontalAlignment="Right"
                            Background="{ThemeResource AppWarningSoftBrush}"
                            BorderBrush="{ThemeResource AppWarningBrush}"
                            BorderThickness="{StaticResource AppCardBorderThickness}"
                            CornerRadius="{StaticResource AppControlCornerRadius}"
                            Visibility="{Binding DirtyBadgeVisibility}">
                            <TextBlock
                                FontSize="{StaticResource AppCaptionFontSize}"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource AppWarningBrush}"
                                Text="{Binding Texts.VapourSynthModifiedBadge}" />
                        </Border>
                        <TextBlock
                            MaxWidth="560"
                            HorizontalAlignment="Right"
                            Foreground="{ThemeResource SubtleTextBrush}"
                            Text="{Binding WorkspaceStatusText}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontFamily="{StaticResource AppMonoFont}"
                            Foreground="{ThemeResource SubtleTextBrush}"
                            Text="{Binding EditorStatusText}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" x:Name="EditorSurfaceHost">
                <Border x:Name="EditorOverlay" Padding="28" Background="{ThemeResource CardAltBrush}" Visibility="Visible">
                    <StackPanel MaxWidth="520" Spacing="14" VerticalAlignment="Center">
                        <ProgressRing x:Name="EditorLoadingProgressRing" Width="32" Height="32" IsActive="True" />
                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="28" FontWeight="SemiBold" Text="{Binding Texts.VapourSynthWorkspaceTitle}" />
                        <TextBlock x:Name="EditorOverlayTextBlock" Text="{Binding WorkspaceStatusText}" TextWrapping="WrapWholeWords" />
                        <Button
                            x:Name="RetryEditorButton"
                            Width="160"
                            AutomationProperties.Name="{Binding Texts.VapourSynthEditorRetryButton}"
                            Click="RetryEditorButton_Click"
                            ToolTipService.ToolTip="{Binding Texts.VapourSynthEditorRetryButton}"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppCommandIconTextSpacing}">
                                <SymbolIcon Symbol="Refresh" />
                                <TextBlock Text="{Binding Texts.VapourSynthEditorRetryButton}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <WebView2 x:Name="EditorWebView" Visibility="Collapsed" />
            </Grid>

            <Border Grid.Row="3" Background="{ThemeResource CardBorderBrush}" />

            <Grid Grid.Row="4" MinHeight="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid
                    Grid.Row="0"
                    Padding="16,10,16,8"
                    Background="{ThemeResource CardAltBrush}"
                    ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        FontFamily="{StaticResource AppDisplayFont}"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding Texts.VapourSynthLogTitle}" />

                    <Button
                        Grid.Column="1"
                        Padding="12,4"
                        Click="ClearLogButton_Click"
                        AutomationProperties.Name="{Binding Texts.VapourSynthClearLogButton}"
                        ToolTipService.ToolTip="{Binding Texts.VapourSynthClearLogButton}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Delete" />
                            <TextBlock Text="{Binding Texts.VapourSynthClearLogButton}" />
                        </StackPanel>
                    </Button>
                </Grid>

                <TextBox
                    x:Name="LogTextBox"
                    Grid.Row="1"
                    Padding="16,10,16,14"
                    AcceptsReturn="True"
                    Background="Transparent"
                    BorderThickness="0"
                    FontFamily="{StaticResource AppMonoFont}"
                    IsReadOnly="True"
                    IsSpellCheckEnabled="False"
                    MinHeight="0"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    Text="{Binding LogText, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
