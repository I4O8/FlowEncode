<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="FlowEncode.Controls.AudioProcessing.AudioProcessingView"
    x:Name="RootView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="ContentStack" Padding="28,16,28,28" Spacing="20">
            <Grid x:Name="WorkspaceGrid" ColumnSpacing="20" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="WorkspacePrimaryRow" Height="Auto" />
                    <RowDefinition x:Name="WorkspaceSecondaryRow" Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="PrimaryColumn" Width="0.95*" />
                    <ColumnDefinition x:Name="SecondaryColumn" Width="1.05*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="PrimaryPanel" Padding="22" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppLargeCornerRadius}" DataContext="{Binding Form}">
                    <StackPanel Spacing="12">
                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="24" FontWeight="SemiBold" Text="{Binding Texts.AudioProcessingTitle}" />

                        <Grid x:Name="AudioSourcePathGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="AudioSourcePathInputColumn" Width="*" />
                                <ColumnDefinition x:Name="AudioSourcePathActionColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AudioSourcePathTextBox" Header="{Binding Texts.SourceHeader}" Text="{Binding AudioProcessingSourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button x:Name="AudioSourceBrowseButton" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" AutomationProperties.Name="{Binding Texts.BrowseButton}" Click="BrowseAudioSourceButton_Click" ToolTipService.ToolTip="{Binding Texts.BrowseButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="OpenFile" />
                                    <TextBlock Text="{Binding Texts.BrowseButton}" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding AudioSourceInfoText}" TextWrapping="WrapWholeWords" />

                        <Grid x:Name="AudioOutputPathGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="AudioOutputPathInputColumn" Width="*" />
                                <ColumnDefinition x:Name="AudioOutputPathActionColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AudioOutputPathTextBox" Header="{Binding AudioProcessingOutputHeader}" Text="{Binding AudioProcessingOutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button x:Name="AudioOutputBrowseButton" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" AutomationProperties.Name="{Binding AudioProcessingOutputBrowseButtonText}" Click="BrowseAudioOutputButton_Click" ToolTipService.ToolTip="{Binding AudioProcessingOutputBrowseButtonText}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Folder" />
                                    <TextBlock Text="{Binding AudioProcessingOutputBrowseButtonText}" />
                                </StackPanel>
                            </Button>
                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" FontFamily="{StaticResource AppMonoFont}" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding AudioProcessingOutputPreviewText}" TextWrapping="Wrap" />
                        </Grid>

                        <Grid x:Name="AudioProcessingOptionsGrid" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ComboBox x:Name="AudioWorkflowComboBox" Header="{Binding Texts.AudioWorkflowHeader}" DisplayMemberPath="Label" ItemsSource="{Binding AudioWorkflowOptions}" SelectedItem="{Binding SelectedAudioWorkflow, Mode=TwoWay}" />
                            <ComboBox x:Name="AudioEac3ToOutputFormatComboBox" Grid.Row="1" Header="{Binding Texts.AudioEac3ToOutputFormatHeader}" DisplayMemberPath="Label" ItemsSource="{Binding AudioEac3ToOutputFormatOptions}" SelectedItem="{Binding SelectedAudioEac3ToOutputFormat, Mode=TwoWay}" Visibility="{Binding AudioEac3ToOptionsVisibility}" />
                            <TextBox x:Name="AudioEac3ToAdditionalArgumentsTextBox" Grid.Row="2" Header="{Binding Texts.AudioEac3ToAdditionalArgumentsHeader}" PlaceholderText="{Binding Texts.AudioEac3ToAdditionalArgumentsPlaceholder}" Text="{Binding AudioProcessingAdditionalArguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding AudioEac3ToOptionsVisibility}" />
                            <ComboBox x:Name="AudioOpusBitrateComboBox" Grid.Row="3" Header="{Binding Texts.AudioOpusBitrateHeader}" DisplayMemberPath="Label" ItemsSource="{Binding AudioOpusBitrateOptions}" SelectedItem="{Binding SelectedAudioOpusBitrate, Mode=TwoWay}" Visibility="{Binding AudioOpusOptionsVisibility}" />
                            <StackPanel Grid.Row="4" Spacing="4" Visibility="{Binding AudioOpusOptionsVisibility}">
                                <ToggleSwitch x:Name="AudioOpusMappingFamilyToggle" Header="{Binding Texts.AudioOpusMappingFamilyHeader}" IsOn="{Binding AudioOpusUseMappingFamily1, Mode=TwoWay}" OnContent="{Binding Texts.ToggleOnLabel}" OffContent="{Binding Texts.ToggleOffLabel}" />
                                <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding Texts.AudioOpusMappingFamilyDescription}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>

                        <Border Padding="16" Background="{ThemeResource CardAltBrush}" BorderBrush="{Binding AudioProcessingStatusPanelBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Texts.EnvironmentSectionTitle}" />
                                <TextBlock FontFamily="{StaticResource AppMonoFont}" Text="{Binding AudioCapabilitySummary}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Grid x:Name="AudioProcessingActionGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="AudioProcessingStartColumn" Width="*" />
                                <ColumnDefinition x:Name="AudioProcessingCancelColumn" Width="*" />
                                <ColumnDefinition x:Name="AudioProcessingDeleteColumn" Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="StartAudioProcessingButton" MinHeight="44" FontWeight="SemiBold" HorizontalAlignment="Stretch" AutomationProperties.Name="{Binding Texts.AudioProcessingStartButton}" Click="StartAudioProcessingButton_Click" IsEnabled="{Binding CanStartAudioProcessing}" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="{Binding Texts.AudioProcessingStartButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Play" />
                                    <TextBlock Text="{Binding Texts.AudioProcessingStartButton}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="CancelAudioProcessingButton" Grid.Column="1" MinHeight="44" FontWeight="SemiBold" HorizontalAlignment="Stretch" AutomationProperties.Name="{Binding Texts.AudioProcessingCancelButton}" Click="CancelAudioProcessingButton_Click" IsEnabled="{Binding CanCancelAudioProcessing}" ToolTipService.ToolTip="{Binding Texts.AudioProcessingCancelButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Cancel" />
                                    <TextBlock Text="{Binding Texts.AudioProcessingCancelButton}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="DeleteAudioProcessingButton" Grid.Column="2" MinHeight="44" FontWeight="SemiBold" HorizontalAlignment="Stretch" AutomationProperties.Name="{Binding Texts.AudioProcessingDeleteButton}" Click="DeleteAudioProcessingButton_Click" IsEnabled="{Binding CanClearAudioProcessingTask}" ToolTipService.ToolTip="{Binding Texts.AudioProcessingDeleteButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Delete" />
                                    <TextBlock Text="{Binding Texts.AudioProcessingDeleteButton}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="SecondaryPanel" Grid.Column="1" Padding="22" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppLargeCornerRadius}" DataContext="{Binding Status}">
                    <StackPanel Spacing="12">
                        <Border Padding="16" Background="{ThemeResource CardAltBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Texts.AudioProcessingStatusTitle}" />
                                <TextBlock FontFamily="{StaticResource AppMonoFont}" Text="{Binding AudioProcessingStatusText}" TextWrapping="WrapWholeWords" />
                                <Border Padding="0" Background="{Binding AudioProcessingProgressTrackBrush}" BorderBrush="{Binding AudioProcessingProgressBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                    <Grid Height="72">
                                        <Rectangle RadiusX="8" RadiusY="8" Fill="{Binding AudioProcessingProgressFillBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RenderTransformOrigin="0,0.5">
                                            <Rectangle.RenderTransform>
                                                <ScaleTransform ScaleX="{Binding AudioProcessingProgressValue}" />
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                        <Border Margin="1" Background="{ThemeResource AppProgressOverlayBrush}" CornerRadius="{StaticResource AppCardCornerRadius}" />
                                        <TextBlock FontFamily="{StaticResource AppMonoFont}" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{Binding AudioProcessingProgressPercentText}" TextAlignment="Center" />
                                    </Grid>
                                </Border>
                                <TextBlock FontFamily="{StaticResource AppMonoFont}" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding AudioProcessingProgressSecondaryText}" TextWrapping="WrapWholeWords" Visibility="{Binding AudioProcessingProgressSecondaryVisibility}" />
                            </StackPanel>
                        </Border>

                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="18" FontWeight="SemiBold" Text="{Binding Texts.AudioProcessingCommandTitle}" />
                        <TextBox MinHeight="120" FontFamily="{StaticResource AppMonoFont}" IsReadOnly="True" PlaceholderText="{Binding Texts.AudioProcessingCommandPlaceholder}" Text="{Binding AudioProcessingCommandLine}" TextWrapping="Wrap" />

                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="18" FontWeight="SemiBold" Text="{Binding Texts.AudioProcessingLogTitle}" />
                        <TextBox Height="420" FontFamily="{StaticResource AppMonoFont}" IsReadOnly="True" PlaceholderText="{Binding Texts.AudioProcessingLogPlaceholder}" ScrollViewer.VerticalScrollBarVisibility="Auto" Text="{Binding AudioProcessingLog}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
