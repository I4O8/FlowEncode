<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="FlowEncode.Controls.BluRayDemux.BluRayDemuxView"
    x:Name="RootView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer x:Name="RootScrollViewer" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="ContentStack" Padding="28,16,28,28" Spacing="20">
            <Grid x:Name="WorkspaceGrid" ColumnSpacing="20" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="WorkspacePrimaryRow" Height="Auto" />
                    <RowDefinition x:Name="WorkspaceSecondaryRow" Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="PrimaryColumn" Width="0.92*" />
                    <ColumnDefinition x:Name="SecondaryColumn" Width="1.08*" />
                </Grid.ColumnDefinitions>

                <Grid x:Name="PrimaryPanel" VerticalAlignment="Top" RowSpacing="16" DataContext="{Binding Disc}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="22" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppLargeCornerRadius}">
                        <StackPanel Spacing="12">
                            <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="24" FontWeight="SemiBold" Text="{Binding Texts.BluRayDemuxTitle}" />

                            <Grid x:Name="BluRaySourcePathGrid" ColumnSpacing="12" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="BluRaySourcePathInputColumn" Width="*" />
                                    <ColumnDefinition x:Name="BluRaySourcePathActionColumn" Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="BluRaySourcePathTextBox" Header="{Binding Texts.SourceHeader}" Text="{Binding BluRayDemuxSourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button x:Name="BluRaySourceBrowseButton" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" AutomationProperties.Name="{Binding Texts.BrowseButton}" Click="BrowseBluRaySourceButton_Click" ToolTipService.ToolTip="{Binding Texts.BrowseButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="OpenFile" />
                                        <TextBlock Text="{Binding Texts.BrowseButton}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Grid x:Name="BluRayOutputPathGrid" ColumnSpacing="12" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="BluRayOutputPathInputColumn" Width="*" />
                                    <ColumnDefinition x:Name="BluRayOutputPathActionColumn" Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="BluRayOutputPathTextBox" Header="{Binding Texts.OutputDirectoryHeader}" Text="{Binding BluRayDemuxOutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button x:Name="BluRayOutputBrowseButton" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" AutomationProperties.Name="{Binding Texts.ChooseFolderButton}" Click="BrowseBluRayOutputButton_Click" ToolTipService.ToolTip="{Binding Texts.ChooseFolderButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Folder" />
                                        <TextBlock Text="{Binding Texts.ChooseFolderButton}" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" FontFamily="{StaticResource AppMonoFont}" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding BluRayDemuxOutputPreviewText}" TextWrapping="Wrap" />
                            </Grid>

                            <Grid x:Name="BluRayBackendActionGrid" ColumnSpacing="12" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="BluRayBackendPickerColumn" Width="*" />
                                    <ColumnDefinition x:Name="BluRayBackendActionColumn" Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Header="{Binding Texts.BluRayDemuxBackendHeader}" DisplayMemberPath="Label" ItemsSource="{Binding BluRayDemuxBackendOptions}" SelectedItem="{Binding SelectedBluRayDemuxBackend, Mode=TwoWay}" />
                                <Button x:Name="ScanBluRayButton" Grid.Column="1" MinHeight="40" VerticalAlignment="Bottom" AutomationProperties.Name="{Binding Texts.BluRayDemuxScanButton}" Click="ScanBluRayButton_Click" IsEnabled="{Binding CanScanBluRayDisc}" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="{Binding Texts.BluRayDemuxScanButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Find" />
                                        <TextBlock Text="{Binding Texts.BluRayDemuxScanButton}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Padding="22" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppLargeCornerRadius}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontWeight="SemiBold" Text="{Binding Texts.BluRayPlaylistListTitle}" />
                            <TextBlock Grid.Row="1" FontFamily="{StaticResource AppMonoFont}" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding BluRayDiscSummaryText}" TextWrapping="WrapWholeWords" />
                            <ListView
                                x:Name="BluRayPlaylistListView"
                                Grid.Row="2"
                                MinHeight="280"
                                ItemsSource="{Binding BluRayPlaylists}"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                SelectedItem="{Binding SelectedBluRayPlaylist, Mode=TwoWay}"
                                SelectionChanged="BluRayPlaylistListView_SelectionChanged">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Padding="14" Background="{ThemeResource CardAltBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding Summary}" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="SecondaryPanel" Grid.Column="1" Padding="22" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppLargeCornerRadius}" DataContext="{Binding Task}">
                    <StackPanel Spacing="12">
                        <Grid x:Name="BluRayTrackHeaderGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition x:Name="BluRayTrackHeaderActionColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="18" FontWeight="SemiBold" Text="{Binding Texts.BluRayTracksTitle}" />
                            <StackPanel x:Name="BluRayTrackSelectionActionsPanel" Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button AutomationProperties.Name="{Binding Texts.BluRaySelectAllTracksButton}" Click="SelectAllBluRayTracksButton_Click" IsEnabled="{Binding CanSelectAllBluRayTracks}" ToolTipService.ToolTip="{Binding Texts.BluRaySelectAllTracksButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Accept" />
                                        <TextBlock Text="{Binding Texts.BluRaySelectAllTracksButton}" />
                                    </StackPanel>
                                </Button>
                                <Button AutomationProperties.Name="{Binding Texts.BluRayInvertTracksButton}" Click="InvertBluRayTracksButton_Click" IsEnabled="{Binding CanInvertBluRayTrackSelection}" ToolTipService.ToolTip="{Binding Texts.BluRayInvertTracksButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Switch" />
                                        <TextBlock Text="{Binding Texts.BluRayInvertTracksButton}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding BluRayPlaylistSummaryText}" TextWrapping="WrapWholeWords" />
                        <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding BluRaySelectedTrackSummary}" TextWrapping="WrapWholeWords" />

                        <ListView
                            x:Name="BluRayTrackListView"
                            MinHeight="260"
                            IsItemClickEnabled="True"
                            ItemsSource="{Binding BluRayTracks}"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectionMode="None"
                            ItemClick="BluRayTrackListView_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="14" Background="{ThemeResource CardAltBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                        <StackPanel Spacing="6">
                                            <CheckBox Content="{Binding Title}" IsChecked="{Binding IsSelected, Mode=OneWay}" IsHitTestVisible="False" />
                                            <TextBlock Margin="28,0,0,0" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding Subtitle}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Margin="28,0,0,0" FontFamily="{StaticResource AppMonoFont}" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding OutputPreview}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid x:Name="BluRayDemuxActionGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="BluRayDemuxActionStartColumn" Width="*" />
                                <ColumnDefinition x:Name="BluRayDemuxActionCancelColumn" Width="*" />
                                <ColumnDefinition x:Name="BluRayDemuxActionClearColumn" Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="StartBluRayDemuxButton" MinHeight="44" FontWeight="SemiBold" HorizontalAlignment="Stretch" AutomationProperties.Name="{Binding Texts.BluRayDemuxStartButton}" Click="StartBluRayDemuxButton_Click" IsEnabled="{Binding CanStartBluRayDemux}" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="{Binding Texts.BluRayDemuxStartButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Play" />
                                    <TextBlock Text="{Binding Texts.BluRayDemuxStartButton}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="CancelBluRayDemuxButton" Grid.Column="1" MinHeight="44" FontWeight="SemiBold" HorizontalAlignment="Stretch" AutomationProperties.Name="{Binding Texts.BluRayDemuxCancelButton}" Click="CancelBluRayDemuxButton_Click" IsEnabled="{Binding CanCancelBluRayDemux}" ToolTipService.ToolTip="{Binding Texts.BluRayDemuxCancelButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Cancel" />
                                    <TextBlock Text="{Binding Texts.BluRayDemuxCancelButton}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ClearBluRayDemuxButton" Grid.Column="2" MinHeight="44" FontWeight="SemiBold" HorizontalAlignment="Stretch" AutomationProperties.Name="{Binding Texts.BluRayDemuxClearButton}" Click="ClearBluRayDemuxButton_Click" IsEnabled="{Binding CanClearBluRayDemuxTask}" ToolTipService.ToolTip="{Binding Texts.BluRayDemuxClearButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Delete" />
                                    <TextBlock Text="{Binding Texts.BluRayDemuxClearButton}" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Padding="16" Background="{ThemeResource CardAltBrush}" BorderBrush="{Binding BluRayDemuxStatusPanelBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Texts.BluRayDemuxStatusTitle}" />
                                <Border Padding="0" Background="{Binding BluRayDemuxProgressTrackBrush}" BorderBrush="{Binding BluRayDemuxProgressBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                    <Grid Height="72">
                                        <Rectangle RadiusX="8" RadiusY="8" Fill="{Binding BluRayDemuxProgressFillBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RenderTransformOrigin="0,0.5">
                                            <Rectangle.RenderTransform>
                                                <ScaleTransform ScaleX="{Binding BluRayDemuxProgressValue}" />
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                        <Border Margin="1" Background="{ThemeResource AppProgressOverlayBrush}" CornerRadius="{StaticResource AppCardCornerRadius}" />
                                        <TextBlock FontFamily="{StaticResource AppMonoFont}" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Text="{Binding BluRayDemuxProgressPercentText}" TextAlignment="Center" />
                                    </Grid>
                                </Border>
                                <TextBlock FontFamily="{StaticResource AppMonoFont}" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding BluRayDemuxProgressSecondaryText}" TextWrapping="WrapWholeWords" Visibility="{Binding BluRayDemuxProgressSecondaryVisibility}" />
                            </StackPanel>
                        </Border>

                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="18" FontWeight="SemiBold" Text="{Binding Texts.BluRayDemuxCommandTitle}" />
                        <TextBox MinHeight="120" FontFamily="{StaticResource AppMonoFont}" IsReadOnly="True" PlaceholderText="{Binding Texts.BluRayDemuxCommandPlaceholder}" Text="{Binding BluRayDemuxCommandLine}" TextWrapping="Wrap" />

                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="18" FontWeight="SemiBold" Text="{Binding Texts.BluRayDemuxLogTitle}" />
                        <TextBox Height="360" FontFamily="{StaticResource AppMonoFont}" IsReadOnly="True" PlaceholderText="{Binding Texts.BluRayDemuxLogPlaceholder}" ScrollViewer.VerticalScrollBarVisibility="Auto" Text="{Binding BluRayDemuxLog}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
