<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="FlowEncode.Controls.Templates.TemplatesView"
    x:Name="RootView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="ContentStack" Padding="28,16,28,28" Spacing="20">
            <Grid x:Name="TemplatesWorkspaceGrid" ColumnSpacing="20" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="TemplatesPrimaryColumn" Width="0.94*" />
                    <ColumnDefinition x:Name="TemplatesSecondaryColumn" Width="1.06*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="TemplateLibraryPanel" Grid.Row="0" Grid.Column="0" Padding="22" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppLargeCornerRadius}" DataContext="{Binding Library}">
                    <StackPanel Spacing="12">
                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="22" FontWeight="SemiBold" Text="{Binding Texts.TemplateLibraryTitle}" />
                        <TextBox PlaceholderText="{Binding Texts.TemplateSearchPlaceholder}" Text="{Binding TemplateSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Grid>
                            <ListView x:Name="TemplateLibraryList" ItemsSource="{Binding TemplateLibraryItems}" SelectionChanged="TemplateLibraryList_SelectionChanged" SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Padding="16" Background="{Binding BackgroundBrush}" BorderBrush="{Binding BorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="6">
                                                    <Grid ColumnSpacing="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="18" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="WrapWholeWords" />
                                                        <Border Grid.Column="1" Padding="10,4" Background="{Binding BadgeBackgroundBrush}" CornerRadius="{StaticResource AppControlCornerRadius}">
                                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding BadgeForegroundBrush}" Text="{Binding SourceLabel}" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding EncoderAndQualityText}" TextWrapping="WrapWholeWords" />
                                                    <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding MetaText}" TextWrapping="WrapWholeWords" Visibility="{Binding MetaVisibility}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
                                                    <Button MinWidth="40" Padding="10" VerticalAlignment="Top" AutomationProperties.Name="{Binding PinActionLabel}" CommandParameter="{Binding}" Tag="{Binding TemplateId}" Click="PinTemplateButton_Click" Visibility="{Binding PinVisibility}" ToolTipService.ToolTip="{Binding PinActionLabel}">
                                                        <SymbolIcon Symbol="{Binding PinSymbol}" />
                                                    </Button>
                                                    <Button MinWidth="40" Padding="10" VerticalAlignment="Top" AutomationProperties.Name="{Binding DataContext.Texts.DeleteTemplateButton, ElementName=RootView}" CommandParameter="{Binding}" Tag="{Binding TemplateId}" Click="DeleteTemplateButton_Click" Visibility="{Binding DeleteVisibility}" ToolTipService.ToolTip="{Binding DataContext.Texts.DeleteTemplateButton, ElementName=RootView}">
                                                        <SymbolIcon Symbol="Delete" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding Texts.TemplateNoMatch}" Visibility="{Binding TemplateLibraryEmptyVisibility}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="TemplateEditorPanel" Grid.Row="0" Grid.Column="1" Padding="22" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppLargeCornerRadius}" DataContext="{Binding Editor}">
                    <StackPanel Spacing="12">
                        <Grid x:Name="TemplateEditorHeaderGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="TemplateEditorTitleColumn" Width="*" />
                                <ColumnDefinition x:Name="TemplateEditorActionsColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="22" FontWeight="SemiBold" Text="{Binding Texts.TemplateEditorTitle}" />
                            <CommandBar x:Name="TemplateEditorCommandBar" Grid.Column="1" Background="Transparent" DefaultLabelPosition="Right" IsDynamicOverflowEnabled="True" OverflowButtonVisibility="Auto">
                                <AppBarButton Icon="Add" Label="{Binding Texts.NewButton}" Click="NewTemplateButton_Click" />
                                <AppBarButton Icon="Save" Label="{Binding Texts.SaveButton}" Click="SaveTemplateButton_Click" IsEnabled="{Binding CanEditTemplateDraft}" />
                                <AppBarButton Icon="OpenFile" Label="{Binding Texts.ImportButton}" Click="ImportTemplateButton_Click" />
                                <AppBarButton Icon="SaveLocal" Label="{Binding Texts.ExportButton}" Click="ExportTemplateButton_Click" />
                            </CommandBar>
                        </Grid>

                        <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding SelectedProfileCaption}" TextWrapping="WrapWholeWords" />
                        <TextBox Header="{Binding Texts.TemplateNameHeader}" IsEnabled="{Binding CanEditTemplateDraft}" Text="{Binding DraftTemplateName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Header="{Binding Texts.NotesHeader}" AcceptsReturn="True" IsEnabled="{Binding CanEditTemplateDraft}" MinHeight="96" Text="{Binding DraftTemplateNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />

                        <Grid x:Name="TemplateEncoderFormatGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="TemplateEncoderColumn" Width="*" />
                                <ColumnDefinition x:Name="TemplateOutputColumn" Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="TemplateEncoderComboBox" Header="{Binding Texts.EncoderHeader}" DisplayMemberPath="Label" IsEnabled="{Binding CanEditTemplateDraft}" ItemsSource="{Binding EncoderOptions}" SelectedItem="{Binding SelectedEncoder, Mode=TwoWay}" />
                            <ComboBox x:Name="TemplateOutputComboBox" Grid.Column="1" Header="{Binding Texts.OutputFormatHeader}" DisplayMemberPath="Label" IsEnabled="{Binding CanEditTemplateDraft}" ItemsSource="{Binding AvailableOutputFormats}" SelectedItem="{Binding SelectedOutputFormat, Mode=TwoWay}" />
                        </Grid>

                        <Grid x:Name="TemplateRatePresetTuneGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="TemplateRateColumn" Width="*" />
                                <ColumnDefinition x:Name="TemplatePresetColumn" Width="*" />
                                <ColumnDefinition x:Name="TemplateTuneColumn" Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="TemplateRateControlComboBox" Header="{Binding Texts.RateControlHeader}" DisplayMemberPath="Label" IsEnabled="{Binding CanEditTemplateDraft}" ItemsSource="{Binding AvailableRateControlModes}" SelectedItem="{Binding SelectedRateControl, Mode=TwoWay}" />
                            <ComboBox x:Name="TemplatePresetComboBox" Grid.Column="1" Header="Preset" DisplayMemberPath="Label" IsEnabled="{Binding CanEditTemplateDraft}" ItemsSource="{Binding AvailablePresets}" SelectedItem="{Binding SelectedPreset, Mode=TwoWay}" />
                            <ComboBox x:Name="TemplateTuneComboBox" Grid.Column="2" Header="Tune" DisplayMemberPath="Label" IsEnabled="{Binding CanEditTemplateDraft}" ItemsSource="{Binding AvailableTunes}" SelectedItem="{Binding SelectedTune, Mode=TwoWay}" />
                        </Grid>

                        <Grid x:Name="TemplateProfileQualityGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="TemplateProfileColumn" Width="*" />
                                <ColumnDefinition x:Name="TemplateQualityGroupColumn" Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="TemplateProfileComboBox" Header="Profile" DisplayMemberPath="Label" IsEnabled="{Binding CanEditTemplateDraft}" ItemsSource="{Binding AvailableProfiles}" SelectedItem="{Binding SelectedProfileOption, Mode=TwoWay}" />
                            <Grid x:Name="TemplateQualityBitrateGrid" Grid.Column="1" ColumnSpacing="12" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="TemplateQualityColumn" Width="*" />
                                    <ColumnDefinition x:Name="TemplateBitrateColumn" Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid x:Name="TemplateQualityContainer" Visibility="{Binding DraftQualityVisibility}">
                                    <NumberBox Header="{Binding QualityInputLabel}" Minimum="0" IsEnabled="{Binding CanEditTemplateDraft}" SmallChange="0.5" SpinButtonPlacementMode="Inline" Value="{Binding DraftQuality, Mode=TwoWay}" />
                                </Grid>
                                <Grid x:Name="TemplateBitrateContainer" Grid.Column="1" Visibility="{Binding DraftBitrateVisibility}">
                                    <NumberBox Header="{Binding BitrateInputLabel}" Minimum="1" IsEnabled="{Binding CanEditTemplateDraft}" SmallChange="100" SpinButtonPlacementMode="Inline" Value="{Binding DraftBitrate, Mode=TwoWay}" />
                                </Grid>
                            </Grid>
                        </Grid>

                        <TextBox Header="{Binding Texts.AdditionalArgumentsHeader}" AcceptsReturn="True" IsEnabled="{Binding CanEditTemplateDraft}" MinHeight="120" Text="{Binding DraftAdditionalArguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                        <TextBlock Foreground="{ThemeResource AppWarningBrush}" Text="{Binding DraftConstraintWarningText}" TextWrapping="WrapWholeWords" Visibility="{Binding DraftConstraintWarningVisibility}" />

                        <TextBox Header="{Binding Texts.UhdArgumentsHeader}" AcceptsReturn="True" IsEnabled="{Binding CanEditTemplateDraft}" MinHeight="88" Text="{Binding DraftUhdParameters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" Visibility="{Binding X265UhdVisibility}" />

                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="18" FontWeight="SemiBold" Text="{Binding Texts.CommandPreviewTitle}" />
                        <TextBox MinHeight="280" FontFamily="{StaticResource AppMonoFont}" IsReadOnly="True" Text="{Binding PreviewCommandLine, Mode=OneWay}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
