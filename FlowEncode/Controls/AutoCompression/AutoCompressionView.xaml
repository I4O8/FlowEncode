<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="FlowEncode.Controls.AutoCompression.AutoCompressionView"
    x:Name="RootView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="ContentStack" Padding="28,16,28,28" Spacing="20">
            <Border Padding="22" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppLargeCornerRadius}">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="12" DataContext="{Binding Form}">
                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="24" FontWeight="SemiBold" Text="{Binding Texts.AutoCompressionTitle}" />
                        <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding Texts.AutoCompressionDescription}" TextWrapping="WrapWholeWords" />

                        <Grid x:Name="AutoSourcePathGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="AutoSourcePathInputColumn" Width="*" />
                                <ColumnDefinition x:Name="AutoSourcePathActionColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AutoSourcePathTextBox" Header="{Binding Texts.SourceHeader}" PlaceholderText="{Binding Texts.SourcePlaceholder}" Text="{Binding AutoCompressionSourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button x:Name="AutoSourceBrowseButton" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" AutomationProperties.Name="{Binding Texts.BrowseButton}" Click="BrowseAutoSourceButton_Click" ToolTipService.ToolTip="{Binding Texts.BrowseButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="OpenFile" />
                                    <TextBlock Text="{Binding Texts.BrowseButton}" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid x:Name="AutoOutputPathGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="AutoOutputPathInputColumn" Width="*" />
                                <ColumnDefinition x:Name="AutoOutputPathActionColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AutoOutputPathTextBox" Header="{Binding Texts.OutputDirectoryHeader}" Text="{Binding AutoCompressionOutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button x:Name="AutoOutputBrowseButton" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" AutomationProperties.Name="{Binding Texts.ChooseFolderButton}" Click="BrowseAutoOutputButton_Click" ToolTipService.ToolTip="{Binding Texts.ChooseFolderButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Folder" />
                                    <TextBlock Text="{Binding Texts.ChooseFolderButton}" />
                                </StackPanel>
                            </Button>
                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" FontFamily="{StaticResource AppMonoFont}" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding AutoCompressionOutputPreviewText}" TextWrapping="Wrap" />
                        </Grid>

                        <Grid x:Name="AutoCompressionOptionsGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="AutoCompressionEncoderColumn" Width="*" />
                                <ColumnDefinition x:Name="AutoCompressionTargetColumn" Width="*" />
                                <ColumnDefinition x:Name="AutoCompressionProbesColumn" Width="*" />
                                <ColumnDefinition x:Name="AutoCompressionWorkersColumn" Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="AutoCompressionEncoderComboBox" Header="{Binding Texts.EncoderHeader}" DisplayMemberPath="Label" ItemsSource="{Binding EncoderOptions}" SelectedItem="{Binding SelectedAutoEncoder, Mode=TwoWay}" />
                            <NumberBox x:Name="AutoCompressionTargetVmafBox" Grid.Column="1" Header="{Binding Texts.AutoCompressionTargetVmafHeader}" Minimum="1" Maximum="100" SmallChange="0.5" SpinButtonPlacementMode="Inline" Value="{Binding AutoCompressionTargetVmaf, Mode=TwoWay}" />
                            <NumberBox x:Name="AutoCompressionProbesBox" Grid.Column="2" Header="{Binding Texts.AutoCompressionProbesHeader}" Minimum="1" Maximum="50" SmallChange="1" SpinButtonPlacementMode="Inline" Value="{Binding AutoCompressionProbes, Mode=TwoWay}" />
                            <NumberBox x:Name="AutoCompressionWorkersBox" Grid.Column="3" Header="{Binding Texts.AutoCompressionWorkersHeader}" Minimum="0" Maximum="64" SmallChange="1" SpinButtonPlacementMode="Inline" Value="{Binding AutoCompressionWorkers, Mode=TwoWay}" />
                        </Grid>

                        <TextBox
                            Header="{Binding Texts.AutoCompressionSmallParametersHeader}"
                            PlaceholderText="--preset 6 --film-grain 8"
                            Text="{Binding AutoCompressionVideoParameters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid x:Name="AutoCompressionActionGrid" ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="AutoCompressionStartColumn" Width="*" />
                                <ColumnDefinition x:Name="AutoCompressionCancelColumn" Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="StartAutoCompressionButton" MinHeight="44" FontWeight="SemiBold" HorizontalAlignment="Stretch" AutomationProperties.Name="{Binding Texts.AutoCompressionStartButton}" Click="StartAutoCompressionButton_Click" IsEnabled="{Binding CanStartAutoCompression}" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="{Binding Texts.AutoCompressionStartButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Play" />
                                    <TextBlock Text="{Binding Texts.AutoCompressionStartButton}" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="CancelAutoCompressionButton" Grid.Column="1" MinHeight="44" FontWeight="SemiBold" HorizontalAlignment="Stretch" AutomationProperties.Name="{Binding Texts.AutoCompressionCancelButton}" Click="CancelAutoCompressionButton_Click" IsEnabled="{Binding CanCancelAutoCompression}" ToolTipService.ToolTip="{Binding Texts.AutoCompressionCancelButton}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Cancel" />
                                    <TextBlock Text="{Binding Texts.AutoCompressionCancelButton}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="12" DataContext="{Binding Status}">
                        <Border Padding="16" Background="{ThemeResource CardAltBrush}" BorderBrush="{Binding AutoCompressionStatusPanelBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Texts.AutoCompressionStatusTitle}" />
                                <TextBlock FontFamily="{StaticResource AppMonoFont}" Text="{Binding AutoCompressionStatusText}" TextWrapping="WrapWholeWords" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ProgressBar
                                    Minimum="0"
                                    Maximum="100"
                                    IsIndeterminate="{Binding AutoCompressionProgressIsIndeterminate}"
                                    Value="{Binding AutoCompressionProgressPercent}" />
                                <TextBlock Grid.Column="1" FontFamily="{StaticResource AppMonoFont}" VerticalAlignment="Center" Text="{Binding AutoCompressionProgressLabel}" />
                            </Grid>
                            <TextBlock
                                FontFamily="{StaticResource AppMonoFont}"
                                Foreground="{ThemeResource SubtleTextBrush}"
                                Text="{Binding AutoCompressionProgressHint}"
                                Visibility="{Binding AutoCompressionProgressHintVisibility}" />
                        </StackPanel>
                        </Border>

                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="18" FontWeight="SemiBold" Text="{Binding Texts.AutoCompressionCommandTitle}" />
                        <TextBox MinHeight="120" FontFamily="{StaticResource AppMonoFont}" IsReadOnly="True" PlaceholderText="{Binding Texts.AutoCompressionCommandPlaceholder}" Text="{Binding AutoCompressionCommandLine}" TextWrapping="Wrap" />

                        <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="18" FontWeight="SemiBold" Text="{Binding Texts.AutoCompressionLogTitle}" />
                        <TextBox MinHeight="320" FontFamily="{StaticResource AppMonoFont}" IsReadOnly="True" PlaceholderText="{Binding Texts.AutoCompressionLogPlaceholder}" ScrollViewer.VerticalScrollBarVisibility="Auto" Text="{Binding AutoCompressionLog}" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
