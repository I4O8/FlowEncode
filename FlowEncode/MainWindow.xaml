<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="FlowEncode.MainWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vs="using:FlowEncode.Controls.VapourSynth"
    Title="FlowEncode"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="RootLayout" AllowDrop="True" Background="{ThemeResource WindowBackgroundBrush}" DragOver="RootLayout_DragOver" DragLeave="RootLayout_DragLeave" Drop="RootLayout_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="FlowEncode">
            <TitleBar.IconSource>
                <ImageIconSource>
                    <ImageIconSource.ImageSource>
                        <BitmapImage UriSource="ms-appx:///Assets/FlowEncodeHammer.png" />
                    </ImageIconSource.ImageSource>
                </ImageIconSource>
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="ShellNavigationView"
            Grid.Row="1"
            AlwaysShowHeader="False"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="240"
            SelectionChanged="ShellNavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="{Binding Texts.NavDashboard}" Icon="Home" IsSelected="True" Tag="dashboard" />
                <NavigationViewItem Content="{Binding Texts.NavBluRayDemux}" Icon="Library" Tag="bluray-demux" />
                <NavigationViewItem Content="{Binding Texts.NavVapourSynthWorkspace}" Icon="Edit" Tag="vapoursynth-workspace" />
                <NavigationViewItem Content="{Binding Texts.NavOverview}" Icon="Video" Tag="overview" />
                <NavigationViewItem Content="{Binding Texts.NavTemplates}" Icon="AllApps" Tag="templates" />
                <NavigationViewItem Content="{Binding Texts.NavAudioProcessing}" Icon="Audio" Tag="audio-process" />
                <NavigationViewItem Content="{Binding Texts.NavAutoCompression}" Icon="Play" Tag="auto-compress" />
                <NavigationViewItem Content="{Binding Texts.NavSettings}" Icon="Setting" Tag="settings" />
            </NavigationView.MenuItems>

            <Grid>
                <ScrollViewer x:Name="DashboardPanel" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DashboardContentStack" Padding="28,16,28,28" Spacing="24">
                        <Border x:Name="DashboardHeroCard" MinHeight="148" Padding="24" Background="{ThemeResource HeroBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppLargeCornerRadius}">
                            <Grid x:Name="DashboardHeroGrid" ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel x:Name="DashboardHeaderPanel" HorizontalAlignment="Left" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock x:Name="DashboardHeaderTitle" HorizontalAlignment="Left" FontFamily="{StaticResource AppDisplayFont}" FontSize="38" FontWeight="SemiBold" Text="FlowEncode" TextWrapping="WrapWholeWords" />
                                    <TextBlock HorizontalAlignment="Left" MaxWidth="760" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding Texts.DashboardDescription}" TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <Border x:Name="DashboardHeroIconFrame" Grid.Column="1" Width="136" Height="136" Padding="0" Background="Transparent" BorderThickness="0" CornerRadius="0">
                                    <Image Stretch="Uniform" AutomationProperties.AccessibilityView="Raw">
                                        <Image.Source>
                                            <BitmapImage UriSource="ms-appx:///Assets/FlowEncodeHammer.png" />
                                        </Image.Source>
                                    </Image>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid x:Name="DashboardCardGrid" ColumnSpacing="20" RowSpacing="20" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="DashboardRow0" Height="Auto" />
                                <RowDefinition x:Name="DashboardRow1" Height="Auto" />
                                <RowDefinition x:Name="DashboardRow2" Height="Auto" />
                                <RowDefinition x:Name="DashboardRow3" Height="Auto" />
                                <RowDefinition x:Name="DashboardRow4" Height="Auto" />
                                <RowDefinition x:Name="DashboardRow5" Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="DashboardPrimaryColumn" Width="*" />
                                <ColumnDefinition x:Name="DashboardSecondaryColumn" Width="*" />
                                <ColumnDefinition x:Name="DashboardTertiaryColumn" Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="DashboardDemuxButton" Grid.Row="0" Grid.Column="0" MinHeight="188" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" AutomationProperties.Name="{Binding Texts.NavBluRayDemux}" Background="Transparent" BorderThickness="0" Click="DashboardCardButton_Click" Tag="bluray-demux" ToolTipService.ToolTip="{Binding Texts.NavBluRayDemux}">
                                <Border Padding="26" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                    <Grid RowSpacing="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Viewbox Width="28" Height="28" HorizontalAlignment="Left">
                                            <SymbolIcon Symbol="Library" />
                                        </Viewbox>

                                        <StackPanel Grid.Row="1" Spacing="8">
                                            <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="26" FontWeight="SemiBold" Text="{Binding Texts.NavBluRayDemux}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource SubtleTextBrush}" MaxLines="3" Text="{Binding Texts.DashboardDemuxCardDescription}" TextTrimming="CharacterEllipsis" TextWrapping="WrapWholeWords" />
                                        </StackPanel>

                                        <Grid Grid.Row="2" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Texts.DashboardOpenModuleButton}" />
                                            <SymbolIcon Grid.Column="1" Symbol="Forward" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Button>

                            <Button x:Name="DashboardVapourSynthButton" Grid.Row="0" Grid.Column="1" MinHeight="188" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" AutomationProperties.Name="{Binding Texts.NavVapourSynthWorkspace}" Background="Transparent" BorderThickness="0" Click="DashboardCardButton_Click" Tag="vapoursynth-workspace" ToolTipService.ToolTip="{Binding Texts.NavVapourSynthWorkspace}">
                                <Border Padding="26" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                    <Grid RowSpacing="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Viewbox Width="28" Height="28" HorizontalAlignment="Left">
                                            <SymbolIcon Symbol="Edit" />
                                        </Viewbox>

                                        <StackPanel Grid.Row="1" Spacing="8">
                                            <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="26" FontWeight="SemiBold" Text="{Binding Texts.NavVapourSynthWorkspace}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource SubtleTextBrush}" MaxLines="3" Text="{Binding Texts.DashboardVapourSynthCardDescription}" TextTrimming="CharacterEllipsis" TextWrapping="WrapWholeWords" />
                                        </StackPanel>

                                        <Grid Grid.Row="2" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Texts.DashboardOpenModuleButton}" />
                                            <SymbolIcon Grid.Column="1" Symbol="Forward" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Button>

                            <Button x:Name="DashboardVideoEncodeButton" Grid.Row="0" Grid.Column="2" MinHeight="188" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" AutomationProperties.Name="{Binding Texts.NavOverview}" Background="Transparent" BorderThickness="0" Click="DashboardCardButton_Click" Tag="overview" ToolTipService.ToolTip="{Binding Texts.NavOverview}">
                                <Border Padding="26" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                    <Grid RowSpacing="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Viewbox Width="28" Height="28" HorizontalAlignment="Left">
                                            <SymbolIcon Symbol="Video" />
                                        </Viewbox>

                                        <StackPanel Grid.Row="1" Spacing="8">
                                            <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="26" FontWeight="SemiBold" Text="{Binding Texts.NavOverview}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource SubtleTextBrush}" MaxLines="3" Text="{Binding Texts.DashboardVideoEncodeCardDescription}" TextTrimming="CharacterEllipsis" TextWrapping="WrapWholeWords" />
                                        </StackPanel>

                                        <Grid Grid.Row="2" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Texts.DashboardOpenModuleButton}" />
                                            <SymbolIcon Grid.Column="1" Symbol="Forward" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Button>

                            <Button x:Name="DashboardAudioButton" Grid.Row="1" Grid.Column="0" MinHeight="188" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" AutomationProperties.Name="{Binding Texts.NavAudioProcessing}" Background="Transparent" BorderThickness="0" Click="DashboardCardButton_Click" Tag="audio-process" ToolTipService.ToolTip="{Binding Texts.NavAudioProcessing}">
                                <Border Padding="26" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                    <Grid RowSpacing="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Viewbox Width="28" Height="28" HorizontalAlignment="Left">
                                            <SymbolIcon Symbol="Audio" />
                                        </Viewbox>

                                        <StackPanel Grid.Row="1" Spacing="8">
                                            <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="26" FontWeight="SemiBold" Text="{Binding Texts.NavAudioProcessing}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource SubtleTextBrush}" MaxLines="3" Text="{Binding Texts.DashboardAudioTranscodeCardDescription}" TextTrimming="CharacterEllipsis" TextWrapping="WrapWholeWords" />
                                        </StackPanel>

                                        <Grid Grid.Row="2" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Texts.DashboardOpenModuleButton}" />
                                            <SymbolIcon Grid.Column="1" Symbol="Forward" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Button>

                            <Button x:Name="DashboardAutoCompressionButton" Grid.Row="1" Grid.Column="1" MinHeight="188" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" AutomationProperties.Name="{Binding Texts.NavAutoCompression}" Background="Transparent" BorderThickness="0" Click="DashboardCardButton_Click" Tag="auto-compress" ToolTipService.ToolTip="{Binding Texts.NavAutoCompression}">
                                <Border Padding="26" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                    <Grid RowSpacing="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Viewbox Width="28" Height="28" HorizontalAlignment="Left">
                                            <SymbolIcon Symbol="Play" />
                                        </Viewbox>

                                        <StackPanel Grid.Row="1" Spacing="8">
                                            <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="26" FontWeight="SemiBold" Text="{Binding Texts.NavAutoCompression}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource SubtleTextBrush}" MaxLines="3" Text="{Binding Texts.DashboardAutoCompressionCardDescription}" TextTrimming="CharacterEllipsis" TextWrapping="WrapWholeWords" />
                                        </StackPanel>

                                        <Grid Grid.Row="2" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Texts.DashboardOpenModuleButton}" />
                                            <SymbolIcon Grid.Column="1" Symbol="Forward" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Button>

                            <Button x:Name="DashboardSettingsButton" Grid.Row="1" Grid.Column="2" MinHeight="188" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" AutomationProperties.Name="{Binding Texts.NavSettings}" Background="Transparent" BorderThickness="0" Click="DashboardCardButton_Click" Tag="settings" ToolTipService.ToolTip="{Binding Texts.NavSettings}">
                                <Border Padding="26" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                    <Grid RowSpacing="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Viewbox Width="28" Height="28" HorizontalAlignment="Left">
                                            <SymbolIcon Symbol="Setting" />
                                        </Viewbox>

                                        <StackPanel Grid.Row="1" Spacing="8">
                                            <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="26" FontWeight="SemiBold" Text="{Binding Texts.NavSettings}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Foreground="{ThemeResource SubtleTextBrush}" MaxLines="3" Text="{Binding Texts.DashboardSettingsCardDescription}" TextTrimming="CharacterEllipsis" TextWrapping="WrapWholeWords" />
                                        </StackPanel>

                                        <Grid Grid.Row="2" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Texts.DashboardOpenModuleButton}" />
                                            <SymbolIcon Grid.Column="1" Symbol="Forward" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <vs:VapourSynthWorkspaceView x:Name="VapourSynthWorkspacePanel" Visibility="Collapsed" />

                <ScrollViewer x:Name="OverviewPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="OverviewContentStack" Padding="28,16,28,28" Spacing="0">
                        <Grid x:Name="OverviewWorkspaceGrid" ColumnSpacing="20" RowSpacing="20">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="OverviewWorkspacePrimaryRow" Height="Auto" />
                                <RowDefinition x:Name="OverviewWorkspaceSecondaryRow" Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="OverviewPrimaryColumn" Width="0.85*" />
                                <ColumnDefinition x:Name="OverviewSecondaryColumn" Width="1.15*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="OverviewComposerPanel" Grid.Row="0" Grid.Column="0" Padding="20" Background="{ThemeResource CardBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppLargeCornerRadius}" VerticalAlignment="Stretch">
                                <Grid RowSpacing="14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="24" FontWeight="SemiBold" Text="{Binding Texts.ComposerTitle}" />

                                    <Grid x:Name="SourcePathGrid" Grid.Row="1" ColumnSpacing="12" RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="SourcePathInputColumn" Width="*" />
                                            <ColumnDefinition x:Name="SourcePathActionColumn" Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SourcePathTextBox" Header="{Binding Texts.SourceHeader}" PlaceholderText="{Binding Texts.SourcePlaceholder}" Text="{Binding SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button
                                            x:Name="SourcePathBrowseButton"
                                            Grid.Column="1"
                                            AutomationProperties.Name="{Binding Texts.BrowseButton}"
                                            Click="BrowseSourceButton_Click"
                                            HorizontalAlignment="Right"
                                            ToolTipService.ToolTip="{Binding Texts.BrowseButton}"
                                            VerticalAlignment="Bottom">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <SymbolIcon Symbol="OpenFile" />
                                                <TextBlock Text="{Binding Texts.BrowseButton}" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <Grid x:Name="OutputPathGrid" Grid.Row="2" ColumnSpacing="12" RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="OutputPathInputColumn" Width="*" />
                                            <ColumnDefinition x:Name="OutputPathActionColumn" Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="OutputPathTextBox" Header="{Binding Texts.OutputDirectoryHeader}" Text="{Binding OutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button
                                            x:Name="OutputPathBrowseButton"
                                            Grid.Column="1"
                                            AutomationProperties.Name="{Binding Texts.ChooseFolderButton}"
                                            Click="BrowseOutputButton_Click"
                                            HorizontalAlignment="Right"
                                            ToolTipService.ToolTip="{Binding Texts.ChooseFolderButton}"
                                            VerticalAlignment="Bottom">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <SymbolIcon Symbol="Folder" />
                                                <TextBlock Text="{Binding Texts.ChooseFolderButton}" />
                                            </StackPanel>
                                        </Button>
                                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" FontFamily="{StaticResource AppMonoFont}" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding DraftOutputPreviewText}" TextWrapping="Wrap" />
                                    </Grid>

                                    <Grid x:Name="QueueActionGrid" Grid.Row="3" ColumnSpacing="12" RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="QueueActionPrimaryColumn" Width="*" />
                                            <ColumnDefinition x:Name="QueueActionSecondaryColumn" Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="QueueOnlyButton" MinHeight="44" FontWeight="SemiBold" HorizontalAlignment="Stretch" AutomationProperties.Name="{Binding Texts.QueueButton}" Click="QueueOnlyButton_Click" IsEnabled="{Binding CanQueueJob}" ToolTipService.ToolTip="{Binding Texts.QueueButton}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <SymbolIcon Symbol="Add" />
                                                <TextBlock Text="{Binding Texts.QueueButton}" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="QueueAndStartButton" Grid.Column="1" MinHeight="44" FontWeight="SemiBold" HorizontalAlignment="Stretch" AutomationProperties.Name="{Binding Texts.QueueAndStartButton}" Click="QueueJobButton_Click" IsEnabled="{Binding CanQueueJob}" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="{Binding Texts.QueueAndStartButton}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <SymbolIcon Symbol="Play" />
                                                <TextBlock Text="{Binding Texts.QueueAndStartButton}" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <Grid x:Name="DraftEncoderRatePresetGrid" Grid.Row="4" ColumnSpacing="12" RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="DraftEncoderColumn" Width="*" />
                                            <ColumnDefinition x:Name="DraftRateColumn" Width="*" />
                                            <ColumnDefinition x:Name="DraftPresetColumn" Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="DraftEncoderComboBox" Header="{Binding Texts.EncoderHeader}" DisplayMemberPath="Label" ItemsSource="{Binding EncoderOptions}" SelectedItem="{Binding SelectedEncoder, Mode=TwoWay}" />
                                        <ComboBox x:Name="DraftRateControlComboBox" Grid.Column="1" Header="{Binding Texts.RateControlHeader}" DisplayMemberPath="Label" ItemsSource="{Binding AvailableRateControlModes}" SelectedItem="{Binding SelectedRateControl, Mode=TwoWay}" />
                                        <ComboBox x:Name="DraftPresetComboBox" Grid.Column="2" Header="Preset" DisplayMemberPath="Label" ItemsSource="{Binding AvailablePresets}" SelectedItem="{Binding SelectedPreset, Mode=TwoWay}" />
                                    </Grid>

                                    <Grid x:Name="DraftTuneProfileFormatValueGrid" Grid.Row="5" ColumnSpacing="12" RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="DraftTuneColumn" Width="*" />
                                            <ColumnDefinition x:Name="DraftProfileColumn" Width="*" />
                                            <ColumnDefinition x:Name="DraftOutputFormatColumn" Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="DraftTuneComboBox" Header="Tune" DisplayMemberPath="Label" ItemsSource="{Binding AvailableTunes}" SelectedItem="{Binding SelectedTune, Mode=TwoWay}" />
                                        <ComboBox x:Name="DraftProfileComboBox" Grid.Column="1" Header="Profile" DisplayMemberPath="Label" ItemsSource="{Binding AvailableProfiles}" SelectedItem="{Binding SelectedProfileOption, Mode=TwoWay}" />
                                        <ComboBox x:Name="DraftOutputFormatComboBox" Grid.Column="2" Header="{Binding Texts.OutputFormatHeader}" DisplayMemberPath="Label" ItemsSource="{Binding AvailableOutputFormats}" SelectedItem="{Binding SelectedOutputFormat, Mode=TwoWay}" />
                                    </Grid>

                                    <Border x:Name="DraftRateValuePanel" Grid.Row="6" Padding="16" Background="{ThemeResource CardAltBrush}" BorderBrush="{ThemeResource CardBorderBrush}" BorderThickness="{StaticResource AppCardBorderThickness}" CornerRadius="{StaticResource AppCardCornerRadius}">
                                        <Grid x:Name="DraftRateValueGrid" ColumnSpacing="16" RowSpacing="12" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition x:Name="DraftRateValueInputColumn" Width="240" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding QualityInputLabel}" Visibility="{Binding DraftQualityVisibility}" />
                                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding BitrateInputLabel}" Visibility="{Binding DraftBitrateVisibility}" />
                                            </StackPanel>

                                            <Grid x:Name="DraftRateValueEditorHost" Grid.Column="1" HorizontalAlignment="Stretch">
                                                <Grid x:Name="DraftQualityContainer" Visibility="{Binding DraftQualityVisibility}">
                                                    <NumberBox Minimum="0" MinWidth="184" SmallChange="0.5" SpinButtonPlacementMode="Inline" Value="{Binding DraftQuality, Mode=TwoWay}" />
                                                </Grid>
                                                <Grid x:Name="DraftBitrateContainer" Visibility="{Binding DraftBitrateVisibility}">
                                                    <NumberBox Minimum="1" MinWidth="184" SmallChange="100" SpinButtonPlacementMode="Inline" Value="{Binding DraftBitrate, Mode=TwoWay}" />
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Grid x:Name="OverviewAdvancedSectionGrid" Grid.Row="7" ColumnSpacing="16" RowSpacing="10" VerticalAlignment="Stretch">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition x:Name="OverviewAdvancedSecondaryColumn" Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Grid x:Name="OverviewTemplateActionGrid" Grid.ColumnSpan="2" ColumnSpacing="8" RowSpacing="8" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="OverviewTemplateActionPrimaryColumn" Width="*" />
                                                <ColumnDefinition x:Name="OverviewTemplateActionSecondaryColumn" Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox
                                                x:Name="OverviewTemplatePicker"
                                                Width="160"
                                                MinHeight="40"
                                                DisplayMemberPath="Name"
                                                ItemsSource="{Binding TemplateLibraryItems}"
                                                PlaceholderText="{Binding Texts.LoadTemplateButton}"
                                                SelectionChanged="OverviewTemplatePicker_SelectionChanged" />
