                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>

                                                                    <Grid ColumnSpacing="16">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <StackPanel Spacing="2">
                                                                            <TextBlock FontFamily="{StaticResource AppDisplayFont}" FontSize="21" FontWeight="SemiBold" Text="{Binding Title}" />
                                                                        </StackPanel>

                                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Top">
                                                                            <Button AutomationProperties.Name="{Binding DataContext.Texts.ManualSelectButton, ElementName=RootLayout}" Tag="{Binding Kind}" Click="ManualSelectSetupDependencyButton_Click" IsEnabled="{Binding ManualSelectEnabled}" Visibility="{Binding ManualSelectVisibility}" ToolTipService.ToolTip="{Binding DataContext.Texts.ManualSelectButton, ElementName=RootLayout}">
                                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                    <SymbolIcon Symbol="OpenFile" />
                                                                                    <TextBlock Text="{Binding DataContext.Texts.ManualSelectButton, ElementName=RootLayout}" />
                                                                                </StackPanel>
                                                                            </Button>
                                                                            <Button AutomationProperties.Name="{Binding DataContext.Texts.ClearManualPinButton, ElementName=RootLayout}" Tag="{Binding Kind}" Click="ClearManualPinnedSetupDependencyButton_Click" IsEnabled="{Binding ClearManualPinEnabled}" Visibility="{Binding ClearManualPinVisibility}" ToolTipService.ToolTip="{Binding DataContext.Texts.ClearManualPinButton, ElementName=RootLayout}">
                                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                    <SymbolIcon Symbol="UnPin" />
                                                                                    <TextBlock Text="{Binding DataContext.Texts.ClearManualPinButton, ElementName=RootLayout}" />
                                                                                </StackPanel>
                                                                            </Button>
                                                                            <Button AutomationProperties.Name="{Binding PrimaryActionText}" Tag="{Binding Kind}" Click="InstallSetupDependencyButton_Click" IsEnabled="{Binding PrimaryActionEnabled}" Visibility="{Binding PrimaryActionVisibility}" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="{Binding PrimaryActionText}">
                                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                    <SymbolIcon Symbol="Download" />
                                                                                    <TextBlock Text="{Binding PrimaryActionText}" />
                                                                                </StackPanel>
                                                                            </Button>
                                                                            <Button AutomationProperties.Name="{Binding DataContext.Texts.UninstallButton, ElementName=RootLayout}" Tag="{Binding Kind}" Click="UninstallSetupDependencyButton_Click" IsEnabled="{Binding UninstallActionEnabled}" Visibility="{Binding UninstallVisibility}" ToolTipService.ToolTip="{Binding DataContext.Texts.UninstallButton, ElementName=RootLayout}">
                                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                    <SymbolIcon Symbol="Delete" />
                                                                                    <TextBlock Text="{Binding DataContext.Texts.UninstallButton, ElementName=RootLayout}" />
                                                                                </StackPanel>
                                                                            </Button>
                                                                            <HyperlinkButton AutomationProperties.Name="{Binding DataContext.Texts.ReleasePageButton, ElementName=RootLayout}" Tag="{Binding ReleaseUrl}" Click="OpenUrlButton_Click" Visibility="{Binding ReleaseVisibility}" ToolTipService.ToolTip="{Binding DataContext.Texts.ReleasePageButton, ElementName=RootLayout}">
                                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                    <SymbolIcon Symbol="Link" />
                                                                                    <TextBlock Text="{Binding DataContext.Texts.ReleasePageButton, ElementName=RootLayout}" />
                                                                                </StackPanel>
                                                                            </HyperlinkButton>
                                                                        </StackPanel>
                                                                    </Grid>

                                                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Visibility="{Binding ReadyBadgeVisibility}">
                                                                        <SymbolIcon Symbol="Accept" Foreground="{ThemeResource AppSuccessBrush}" />
                                                                        <TextBlock FontWeight="SemiBold" Foreground="{ThemeResource AppSuccessBrush}" Text="{Binding StatusTitle}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Visibility="{Binding WarningBadgeVisibility}">
                                                                        <SymbolIcon Symbol="Sync" Foreground="{ThemeResource AppWarningBrush}" />
                                                                        <TextBlock FontWeight="SemiBold" Foreground="{ThemeResource AppWarningBrush}" Text="{Binding StatusTitle}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Visibility="{Binding BlockedBadgeVisibility}">
                                                                        <SymbolIcon Symbol="Important" Foreground="{ThemeResource AppErrorBrush}" />
                                                                        <TextBlock FontWeight="SemiBold" Foreground="{ThemeResource AppErrorBrush}" Text="{Binding StatusTitle}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Row="2" Spacing="4">
                                                                        <TextBlock Text="{Binding StatusText}" TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding InstalledVersionText}" TextWrapping="WrapWholeWords" Visibility="{Binding InstalledVersionVisibility}" />
                                                                        <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding LatestVersionText}" TextWrapping="WrapWholeWords" Visibility="{Binding LatestVersionVisibility}" />
                                                                    </StackPanel>

                                                                    <TextBlock Grid.Row="3" Foreground="{ThemeResource AppWarningBrush}" Text="{Binding WarningText}" TextWrapping="WrapWholeWords" Visibility="{Binding WarningVisibility}" />

                                                                    <Grid Grid.Row="4" RowSpacing="6" Visibility="{Binding ProgressVisibility}">
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <TextBlock Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding InstallProgressText}" TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Grid.Column="1" FontFamily="{StaticResource AppMonoFont}" Text="{Binding InstallProgressPercentText}" />
                                                                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="6" Minimum="0" Maximum="100" Value="{Binding InstallProgressPercent}" IsIndeterminate="{Binding IsInstallIndeterminate}" />
                                                                    </Grid>

                                                                    <TextBlock Grid.Row="5" FontFamily="{StaticResource AppMonoFont}" FontSize="{StaticResource AppCaptionFontSize}" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding ExecutablePath}" TextWrapping="WrapWholeWords" Visibility="{Binding PathVisibility}" />

                                                                    <TextBlock Grid.Row="6" FontFamily="{StaticResource AppMonoFont}" FontSize="{StaticResource AppCaptionFontSize}" Foreground="{ThemeResource SubtleTextBrush}" Text="{Binding DetailText}" TextWrapping="WrapWholeWords" Visibility="{Binding DetailVisibility}" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </FlipView.ItemTemplate>
                        </FlipView>

                        <Grid x:Name="SetupGuideFooterPanel" Grid.Row="2" HorizontalAlignment="Center" ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button
                                MinWidth="{StaticResource AppLargeCommandMinWidth}"
                                MinHeight="{StaticResource AppLargeCommandMinHeight}"
                                Padding="{StaticResource AppLargeCommandPadding}"
                                AutomationProperties.Name="{Binding Texts.SetupGuidePreviousButton}"
                                FontSize="{StaticResource AppLargeCommandFontSize}"
                                FontWeight="SemiBold"
                                Click="SetupGuidePreviousButton_Click"
                                IsEnabled="{Binding CanMoveSetupGuidePrevious}"
                                ToolTipService.ToolTip="{Binding Texts.SetupGuidePreviousButton}">
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppCommandIconTextSpacing}">
                                    <SymbolIcon Symbol="Back" />
                                    <TextBlock Text="{Binding Texts.SetupGuidePreviousButton}" />
                                </StackPanel>
                            </Button>

                            <TextBlock
                                Grid.Column="1"
                                Margin="10,0"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource AppMonoFont}"
                                FontSize="{StaticResource AppSectionTitleFontSize}"
                                FontWeight="SemiBold"
                                Text="{Binding SetupGuidePositionText}"
                                Visibility="{Binding SetupGuidePositionVisibility}" />

                            <Button
                                Grid.Column="2"
                                MinWidth="{StaticResource AppLargeCommandMinWidth}"
                                MinHeight="{StaticResource AppLargeCommandMinHeight}"
                                Padding="{StaticResource AppLargeCommandPadding}"
                                AutomationProperties.Name="{Binding SetupGuideForwardButtonText}"
                                FontSize="{StaticResource AppLargeCommandFontSize}"
                                FontWeight="SemiBold"
                                Click="SetupGuideNextButton_Click"
                                IsEnabled="{Binding CanAdvanceOrDismissSetupGuide}"
                                Style="{StaticResource AccentButtonStyle}"
                                ToolTipService.ToolTip="{Binding SetupGuideForwardButtonText}">
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppCommandIconTextSpacing}">
                                    <TextBlock Text="{Binding SetupGuideForwardButtonText}" />
                                    <SymbolIcon Symbol="Forward" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>

